{
  "entities": {
    "User": {
      "title": "User",
      "description": "User preferences and settings.",
      "type": "object",
      "properties": {
        "preferences": {
          "type": "object",
          "properties": {
            "enhancedThinkingEnabled": { "type": "boolean" },
            "chatHistoryEnabled": { "type": "boolean" }
          }
        },
        "theme": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "plan": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "credits": { "type": "integer" },
        "maxCredits": { "type": "integer" },
        "totalMessages": { "type": "integer" },
        "lastActive": { "type": "string", "format": "date-time" }
      }
    },
    "Session": {
      "title": "Session",
      "description": "A chat session containing metadata.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a session.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "parts": { "type": "array" },
        "timestamp": { "type": "number" }
      },
      "required": ["role", "parts", "timestamp"]
    },
    "HowItWorks": {
      "title": "HowItWorks",
      "description": "The content for the 'How It Works' documentation page.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["title", "content"]
    },
    "SystemSettings": {
      "title": "SystemSettings",
      "description": "Global application settings restricted to admins.",
      "type": "object",
      "properties": {
        "registrationEnabled": { "type": "boolean" },
        "registrationDisabledMessage": { "type": "string" },
        "adminCreditsEnabled": { "type": "boolean" }
      }
    },
    "ActiveSession": {
      "title": "ActiveSession",
      "description": "Represents an active visitor session.",
      "type": "object",
      "properties": {
        "lastSeen": { "type": "integer" }
      },
      "required": ["lastSeen"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback on AI response accuracy.",
      "type": "object",
      "properties": {
        "messageId": { "type": "string" },
        "sessionId": { "type": "string" },
        "isAccurate": { "type": "boolean" },
        "userId": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["messageId", "isAccurate", "userId", "timestamp"]
    },
    "FeedPost": {
      "title": "FeedPost",
      "description": "A post in the user community feed.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "number" },
        "isPublic": { "type": "boolean" },
        "postType": { "type": "string", "enum": ["Changes Made", "Upcoming", "The Vision"] },
        "userRole": { "type": "string", "enum": ["user", "admin"] },
        "reactions": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "required": ["userId", "content", "timestamp", "isPublic"]
    }
  },
  "firestore": {
    "/feed/{postId}": {
      "schema": "FeedPost",
      "description": "Public community feed posts."
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Log of user feedback on responses."
    },
    "/presence/{sessionId}": {
      "schema": "ActiveSession",
      "description": "Active users currently on the site."
    },
    "/settings/global": {
      "schema": "SystemSettings",
      "description": "Global application settings."
    },
    "/settings/how-it-works": {
      "schema": "HowItWorks",
      "description": "Global settings for the public-facing 'How It Works' documentation."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and settings."
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Chat sessions belonging to the user."
    },
    "/users/{userId}/sessions/{sessionId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a session."
    }
  }
}
