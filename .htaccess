# cPanel Node.js Selector
# Forward everything to the Node.js application if it's not a real file
RewriteEngine On
RewriteBase /psychelense/

# If the request is for a real file (css, js, image), let Apache serve it
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Otherwise, let the Node.js application handle everything else
# This includes both API routes and SPA frontend routes
RewriteRule ^ node_app.js [L]
